@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

<h2>Environment Info</h2>

<p><b>Environment:</b> @ViewBag.EnvironmentName</p>
<p><b>Web Root:</b> @ViewBag.WebRoot</p>



<h2>Configuration Info</h2>

<p><b>App Name:</b> @Configuration["AppSettings:AppName"]</p>
<p><b>Version:</b> @Configuration["AppSettings:Version"]</p>